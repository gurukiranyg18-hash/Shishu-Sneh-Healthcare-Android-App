<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:orientation="vertical"
    android:padding="20dp">

    <Button
        android:id="@+id/btnGrowth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Growth Chart"/>

    <Button
        android:id="@+id/btnVaccine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vaccination Alert"/>

    <Button
        android:id="@+id/btnFeeding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Feeding Guide"/>

    <Button
        android:id="@+id/btnMilestone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Milestone Checklist"/>

</LinearLayout>
